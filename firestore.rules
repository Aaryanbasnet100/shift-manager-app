rules_version = '2';

// Baseline lockdown: every read/write requires an authenticated session
// (the app signs in anonymously at startup). This stops anyone with the
// public web API key from scraping or mutating Firestore directly.
//
// Deploy with: firebase deploy --only firestore:rules
// Prerequisite: enable Anonymous sign-in under Authentication > Sign-in method.
//
// NOTE: anonymous users are all equal, so this does NOT yet enforce
// per-tenant or per-role permissions server-side. That requires migrating
// to real Firebase Auth accounts (email/password + custom claims), at which
// point these rules should be tightened to match auth.uid against the
// workspace's employee documents.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
